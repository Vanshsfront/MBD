# Copy this to /.env at the repo root, then fill in the placeholders.
# DO NOT commit /.env — it's gitignored.

# ─── Database ─────────────────────────────────────────────────────────
# Default for the Docker setup in docker-postgres.md
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mbd?schema=public

# Used by Prisma migrations only; for our `db push` setup it's identical
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mbd?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────
# Generate a strong value: npx auth secret
AUTH_SECRET=

# ─── Document rendering ──────────────────────────────────────────────
# Path to the LibreOffice soffice binary (DOCX → PDF conversion)
#   Windows:  C:\Program Files\LibreOffice\program\soffice.exe
#   macOS:    /Applications/LibreOffice.app/Contents/MacOS/soffice
#   Linux:    /usr/bin/soffice
SOFFICE_BIN=

# Where consent photos / signature uploads live (relative or absolute)
UPLOAD_DIR=./uploads

# ─── Dev conveniences ────────────────────────────────────────────────
# Set to "true" on a dev box to render the seed-password hint on /login.
# Leave BLANK in production.
NEXT_PUBLIC_SHOW_SEED_HINT=

# Set to "true" to skip the daily node-cron registration (handy in dev).
# Leave BLANK to enable the package-expiry / low-stock / follow-up-due jobs.
DISABLE_CRON=

# ─── Production (NODE_ENV) ───────────────────────────────────────────
# Not set here — controlled at deploy time. When NODE_ENV=production:
#   - the dev@mbd.in super-account is OMITTED from the seed
#   - CSP drops the dev-only 'unsafe-eval' allowance
#   - upgrade-insecure-requests is set in CSP
