generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── CENTRE ──────────────────────────────────────────────

model Centre {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff        Staff[]
  clients      Client[]
  sessions     Session[]
  invoices     Invoice[]
  appointments Appointment[]
  services     Service[]
  misEntries   MisEntry[]
}

// ─── DEPARTMENT ──────────────────────────────────────────

model Department {
  id             String  @id @default(cuid())
  name           String  @unique
  defaultGstRate Float   @default(0)
  isActive       Boolean @default(true)

  services Service[]
  staff    Staff[]
}

// ─── SERVICE ─────────────────────────────────────────────

model Service {
  id               String  @id @default(cuid())
  name             String
  hsnSacCode       String?
  basePrice        Float
  gstRate          Float   @default(0)
  isActive         Boolean @default(true)
  participantCount Int     @default(1) // 1 = individual, 2 = duo, 3 = trio — locks invoice qty

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id])

  consultations    Consultation[]
  sessions         Session[]
  medicalHistories MedicalHistory[]
  inventoryItems   InventoryItem[]
  appointments     Appointment[]

  @@unique([name, departmentId, centreId])
}

// ─── STAFF (Users) ───────────────────────────────────────

model Staff {
  id               String  @id @default(cuid())
  name             String
  email            String  @unique
  passwordHash     String
  role             String  @default("THERAPIST") // OWNER | ADMIN | MANAGER | FRONT_OFFICE | CONSULTANT | THERAPIST
  designation      String?
  isActive         Boolean @default(true)
  signatureDataUrl String? // base64 PNG default signature, used to auto-fill PDFs

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id])

  consultations          Consultation[]
  sessions               Session[]
  alerts                 Alert[]
  auditLogs              AuditLog[]
  preferredByClients     Client[]                 @relation("PreferredTherapist")
  doctorAssignments      ClientDoctorAssignment[]
  appointments           Appointment[]            @relation("TherapistAppointments")
  notifications          Notification[]
  changeRequestsMade     ChangeRequest[]          @relation("ChangeRequester")
  changeRequestsReviewed ChangeRequest[]          @relation("ChangeReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CLIENT ──────────────────────────────────────────────

model Client {
  id                  String    @id @default(cuid())
  clientCode          String    @unique
  firstName           String
  lastName            String
  email               String?
  phone               String
  dob                 DateTime?
  age                 Int?
  sex                 String?
  dominance           String?
  address             String? // JSON string
  emergencyContact    String? // JSON string
  referredBy          String?
  status              String    @default("DRAFT") // DRAFT | ACTIVE | INACTIVE
  visitReasons        String? // JSON array of visit reasons
  photoUrl            String?
  consentFormPhotoUrl String?
  clinicPolicyAcked   Boolean   @default(false)

  // How the patient reached the clinic — captured during the assignment step.
  customerType     String? // WALK_IN | REFERRAL
  referralSourceId String?
  referralSource   ReferralSource? @relation(fields: [referralSourceId], references: [id])

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id])

  preferredTherapistId String?
  preferredTherapist   Staff?  @relation("PreferredTherapist", fields: [preferredTherapistId], references: [id])

  intakeForms       IntakeForm[]
  medicalHistories  MedicalHistory[]
  consultations     Consultation[]
  packages          Package[]
  sessions          Session[]
  invoices          Invoice[]
  alerts            Alert[]
  flags             ClientFlag[]
  dashboardShares   DashboardShare[]
  doctorAssignments ClientDoctorAssignment[]
  appointments      Appointment[]
  misEntries        MisEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── INTAKE FORM ─────────────────────────────────────────

model IntakeForm {
  id                             String  @id @default(cuid())
  selectedServices               String // JSON array string
  formData                       String? // JSON string
  consentSigned                  Boolean @default(false)
  liabilityWaiverSigned          Boolean @default(false)
  commercialTermsAccepted        Boolean @default(false)
  cancellationPolicyAcknowledged Boolean @default(false)
  assignedTo                     String?
  assignedBy                     String?
  frontOfficeExec                String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  visitDateTime DateTime @default(now())
  createdAt     DateTime @default(now())
}

// ─── MEDICAL HISTORY ─────────────────────────────────────

model MedicalHistory {
  id                  String  @id @default(cuid())
  vitals              String? // JSON: weight, height, bmi, pulse, spo2, bp
  comorbidities       String? // JSON: DM, HTN, CAD, PCOS, thyroid, other
  knownAllergies      String?
  chiefComplaints     String?
  pastMedicalHistory  String?
  pastSurgicalHistory String?
  familyHistory       String?
  personalHistory     String? // JSON: sleep, diet, bowel, others
  diagnosis           String?
  currentMedications  String?
  planOfCare          String?
  followUp            String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
}

// ─── CONSULTATION ────────────────────────────────────────

model Consultation {
  id                  String    @id @default(cuid())
  vitals              String? // JSON
  comorbidities       String? // JSON
  chiefComplaints     String?
  diagnosis           String?
  planOfCare          String?
  treatmentProtocol   String?
  recommendedSessions Int?
  assessmentNotes     String? // JSON
  followUp            String?
  isLocked            Boolean   @default(false)
  lockedAt            DateTime?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  consultantId String
  consultant   Staff  @relation(fields: [consultantId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  packages Package[]

  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// ─── PACKAGE ─────────────────────────────────────────────

model Package {
  id                String   @id @default(cuid())
  totalSessions     Int
  completedSessions Int      @default(0)
  serviceMix        String // JSON array of { serviceId, serviceName, count }
  validFrom         DateTime
  validUntil        DateTime
  status            String   @default("ACTIVE") // ACTIVE | EXPIRED | COMPLETED | CANCELLED
  totalPrice        Float
  discountPercent   Float    @default(0)
  discountAmount    Float    @default(0)
  expiryWarningDays Int      @default(14)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])

  sessions Session[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── SESSION ─────────────────────────────────────────────

model Session {
  id               String   @id @default(cuid())
  sessionDate      DateTime
  treatmentNotes   String?
  progressUpdates  String?
  status           String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED | NO_SHOW
  allotments       String? // JSON: [{ therapistId, therapistName, serviceId, serviceName }]
  perSessionAmount Float? // For salary calculation

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  therapistId String
  therapist   Staff  @relation(fields: [therapistId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── INVOICE ─────────────────────────────────────────────

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique
  invoiceType     String    @default("INVOICE") // INVOICE | PROFORMA
  subtotal        Float
  totalGst        Float
  totalAmount     Float
  paidAmount      Float     @default(0)
  discountPercent Float     @default(0)
  discountAmount  Float     @default(0)
  discountType    String    @default("PERCENT") // PERCENT | FLAT
  status          String    @default("DRAFT") // DRAFT | SENT | PAID | PARTIAL | OVERDUE
  dueDate         DateTime?
  validTill       DateTime? // Proforma only
  referredBy      String?
  sacNumber       String?
  hslNumber       String?
  lineItems       String // JSON array
  inventoryItems  String? // JSON array of inventory items included

  promotionId       String?
  promotionCode     String?
  promotionDiscount Float   @default(0)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id])

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id])

  payments   Payment[]
  misEntries MisEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PAYMENT ─────────────────────────────────────────────

model Payment {
  id          String   @id @default(cuid())
  amount      Float
  method      String // CASH | CARD | CHEQUE | NEFT | UPI | RAZORPAY | OTHER
  paymentDate DateTime @default(now())
  reference   String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
}

// ─── ALERT ───────────────────────────────────────────────

model Alert {
  id      String  @id @default(cuid())
  type    String // PACKAGE_EXPIRY | SESSION_BALANCE | FOLLOW_UP | SCHEDULE_GAP | UNPAID_INVOICE | PART_PAYMENT_REMINDER
  message String
  isRead  Boolean @default(false)

  targetUserId String?
  targetUser   Staff?  @relation(fields: [targetUserId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
}

// ─── AUDIT LOG ───────────────────────────────────────────

model AuditLog {
  id       String  @id @default(cuid())
  action   String // CREATE | UPDATE | DELETE
  entity   String // Client | Invoice | Session | Package | Payment etc.
  entityId String
  changes  String? // JSON: { field: { old, new } }
  metadata String? // JSON: extra context

  performedById String
  performedBy   Staff  @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())
}

// ─── CLIENT FLAG ─────────────────────────────────────────

model ClientFlag {
  id       String  @id @default(cuid())
  type     String // VIP | CAUTION | OVERDUE | FOLLOWUP | CUSTOM
  label    String
  color    String  @default("yellow") // red | yellow | green | blue | purple
  notes    String?
  isActive Boolean @default(true)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  createdBy String?
  createdAt DateTime @default(now())
}

// ─── INVENTORY ITEM ──────────────────────────────────────

model InventoryItem {
  id         String  @id @default(cuid())
  name       String
  sku        String? @unique
  category   String? // EQUIPMENT | CONSUMABLE | SUPPLEMENT | OTHER
  unitPrice  Float   @default(0)
  gstRate    Float   @default(0)
  hsnSacCode String?
  stock      Int     @default(0)
  minStock   Int     @default(0)
  isActive   Boolean @default(true)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DASHBOARD SHARE ─────────────────────────────────────

model DashboardShare {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid())
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  visibleSections String    @default("[\"overview\",\"packages\",\"sessions\",\"invoices\"]") // JSON array
  viewCount       Int       @default(0)
  lastAccessedAt  DateTime?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IntakeToken {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid())
  isUsed      Boolean  @default(false)
  expiresAt   DateTime
  formData    String? // JSON: submitted form data from patient
  status      String   @default("PENDING") // PENDING | COMPLETED | EXPIRED
  clientId    String? // Linked after form submission creates a client
  createdById String? // Staff who generated the token
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── APPOINTMENT ─────────────────────────────────────────

model Appointment {
  id              String    @id @default(cuid())
  startTime       DateTime
  endTime         DateTime
  status          String    @default("CONFIRMED") // CONFIRMED | RESCHEDULED | CANCELLED | COMPLETED | QUEUED
  followUpFlag    Boolean   @default(false)
  followUpNote    String?
  queuePosition   Int?
  backupStartTime DateTime?
  backupEndTime   DateTime?
  notes           String?
  cancelledBy     String? // PATIENT | THERAPIST | null
  cancelledReason String?
  cancelledAt     DateTime?
  cancelledById   String? // Staff who recorded the cancellation

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  therapistId String
  therapist   Staff  @relation("TherapistAppointments", fields: [therapistId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CLIENT DOCTOR ASSIGNMENT ────────────────────────────

model ClientDoctorAssignment {
  id                     String    @id @default(cuid())
  comment                String?
  isPrimary              Boolean   @default(false)
  assignedAt             DateTime  @default(now())
  endedAt                DateTime?
  endedReason            String?
  replacedByAssignmentId String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  serviceId   String?
  serviceName String?

  @@unique([clientId, staffId])
}

// ─── NOTIFICATION ────────────────────────────────────────

model Notification {
  id       String  @id @default(cuid())
  type     String // SESSION_REMAINING | PACKAGE_EXPIRY | FOLLOW_UP | SCHEDULE_CHANGE | FORM_UNFILLED
  title    String
  message  String
  isRead   Boolean @default(false)
  priority String  @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  clientId String?
  metadata String? // JSON

  targetUserId String?
  targetUser   Staff?  @relation(fields: [targetUserId], references: [id])

  createdAt DateTime @default(now())
}

// ─── CHANGE REQUEST ──────────────────────────────────────

model ChangeRequest {
  id       String  @id @default(cuid())
  type     String // RESCHEDULE | REASSIGN | OTHER
  details  String // JSON: { appointmentId?, clientId?, currentTherapistId?, newTherapistId?, reason, etc. }
  status   String  @default("PENDING") // PENDING | APPROVED | REJECTED
  response String?

  requesterId String
  requester   Staff  @relation("ChangeRequester", fields: [requesterId], references: [id])

  reviewedById String?
  reviewedBy   Staff?    @relation("ChangeReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ATTENDANCE LOG ──────────────────────────────────────

model AttendanceLog {
  id        String   @id @default(cuid())
  staffId   String?
  clientId  String?
  date      DateTime
  type      String // CHECK_IN | CHECK_OUT
  createdAt DateTime @default(now())
}

// ─── INVENTORY LOG ───────────────────────────────────────

model InventoryLog {
  id              String   @id @default(cuid())
  inventoryItemId String
  action          String // ADDED | USED | ADJUSTED
  quantity        Int
  notes           String?
  performedById   String
  createdAt       DateTime @default(now())
}

// ─── PROMOTION ───────────────────────────────────────────

model Promotion {
  id            String    @id @default(cuid())
  name          String
  code          String    @unique
  description   String?
  discountType  String // PERCENT | FLAT
  discountValue Float
  maxDiscount   Float? // cap for percentage discounts ("upto")
  validFrom     DateTime?
  validUntil    DateTime?
  maxUses       Int? // null = unlimited
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── REFERRAL SOURCE ─────────────────────────────────────

model ReferralSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
}

// ─── MIS ENTRY ───────────────────────────────────────────
// Snapshot of one invoice line item, written at invoice creation time so the
// MIS report does not depend on later edits to the source invoice. Payment
// fields (paidAmount/balance/mode/reference) are mutated as payments arrive.
model MisEntry {
  id String @id @default(cuid())

  // Source links
  invoiceId        String
  invoice          Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceLineIndex Int     @default(0)
  clientId         String
  client           Client  @relation(fields: [clientId], references: [id])
  centreId         String?
  centre           Centre? @relation(fields: [centreId], references: [id])

  // Snapshot fields (frozen at invoice creation)
  centreName         String   @default("Clinic")
  invoiceNumber      String
  invoiceType        String   @default("INVOICE")
  invoiceDate        DateTime
  patientName        String
  patientType        String   @default("New") // New | Existing
  customerType       String? // WALK_IN | REFERRAL — copied from Client at write time
  referralSourceName String?
  consultant         String?
  service            String?
  department         String?

  // Line item amounts
  amount            Float     @default(0) // gross before discount
  discount          Float     @default(0)
  amountBeforeTax   Float     @default(0)
  gstPercent        Float     @default(0)
  gst               Float     @default(0)
  netPayableAmount  Float     @default(0)
  perSessionAmount  Float     @default(0)
  noOfSessions      Int       @default(1)
  sessionNo         Int       @default(1)
  packageStartDate  DateTime?
  previousDues      Float     @default(0)
  previousMonthDues Float     @default(0)

  // Updated when payments arrive
  paidAmount    Float   @default(0)
  balanceAmount Float   @default(0)
  excessAmount  Float   @default(0)
  modeOfPayment String?
  reference     String?

  // Misc
  isBedUsed     String  @default("No")
  remark1       String?
  remark2       String?
  enteredById   String?
  enteredByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([clientId])
  @@index([invoiceDate])
  @@index([centreId])
}
